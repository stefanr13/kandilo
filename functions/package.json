{
  "name": "kandilo-functions",
  "description": "Kandilo Firebase Cloud Functions",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google/genai": "^1.52.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "resend": "^4.8.0",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.8.2"
  },
  "private": true
}
