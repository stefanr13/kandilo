{
  "name": "kandilo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "scripts": {
    "predev": "npm run write:firebase-messaging-sw-config",
    "dev": "vite --port=3000 --host=127.0.0.1",
    "predev:lan": "npm run write:firebase-messaging-sw-config",
    "dev:lan": "vite --port=3000 --host=0.0.0.0",
    "prebuild": "npm run write:firebase-messaging-sw-config",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && npm --prefix functions run lint",
    "test": "vitest run",
    "test:web": "vitest run",
    "test:firebase": "firebase emulators:exec --only firestore,storage \"vitest run --config vitest.firebase.config.ts\"",
    "test:functions": "npm --prefix functions run build && KANDILO_FUNCTIONS_TEST_MODE=true STRIPE_WEBHOOK_SECRET=whsec_kandilo_emulator_test APP_URL=http://localhost:3000 firebase emulators:exec --only auth,firestore,functions \"vitest run --config vitest.functions.config.ts\"",
    "test:watch": "vitest",
    "check:web": "npm run typecheck && npm run test:web",
    "test:qa": "npm run check:web && npm run test:firebase && npm run test:functions && npm run build",
    "check": "npm run lint && npm run test",
    "github:protect-main": "node scripts/configure-github-branch-protection.mjs",
    "write:firebase-messaging-sw-config": "node scripts/write-firebase-messaging-sw-config.mjs",
    "cap:sync": "npm run build && npx cap sync",
    "cap:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "cap:android": "npm run build && npx cap sync android && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@google/genai": "^1.52.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tiptap/extension-character-count": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas-confetti": "^1.9.4",
    "dompurify": "^3.4.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "firebase-admin": "^13.10.0",
    "firebase-tools": "^15.18.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.2"
  }
}
