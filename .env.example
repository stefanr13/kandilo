# ── Gemini AI ────────────────────────────────────────────────────────────────
# Required for the Faith AI screen. Set in AI Studio via the Secrets panel.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ── App URL ───────────────────────────────────────────────────────────────────
APP_URL="https://app.kandilo.org"

# ── Firebase (Client SDK) ─────────────────────────────────────────────────────
# All VITE_ prefixed vars are exposed to the browser bundle.
# These are public identifiers — not secrets. Safe to commit to version control.
# Find them in: Firebase Console → Project Settings → General → Your apps → SDK setup
VITE_FIREBASE_API_KEY="AIza..."
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="123456789"
VITE_FIREBASE_APP_ID="1:123456789:web:abc123"
VITE_FIREBASE_APP_CHECK_SITE_KEY="6L..."
# Optional local development token. Register the debug token in Firebase App Check
# before using it against an App Check-enforced project.
VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=""

# ── Firebase Cloud Messaging (Web Push VAPID key) ─────────────────────────────
# Find in: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
# Click "Generate key pair" if you haven't already.
VITE_FIREBASE_VAPID_KEY="BN..."

# ── Deferred AI UI ───────────────────────────────────────────────────────────
# Keep these false until GEMINI_API_KEY is configured and AI flows are tested.
VITE_ENABLE_FAITH_AI="false"
VITE_ENABLE_AI_WRITER="false"

# ── Cloud Functions: Resend API Key ───────────────────────────────────────────
# Set this as a Firebase secret: firebase functions:secrets:set RESEND_API_KEY
# Do NOT put this in .env files — it is a backend secret.
# RESEND_API_KEY="re_..."
